{
  "version": 8,
  "name": "GCS Terrain",
  "sources": {
    "esri-topo": {
      "type": "raster",
      "tiles": [
        "https://services.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}"
      ],
      "tileSize": 256,
      "minzoom": 0,
      "maxzoom": 19,
      "attribution": "Tiles &copy; Esri",
      "scheme": "xyz"
    }
  },
  "layers": [
    {"id": "background", "type": "background", "paint": {"background-color": "#0a1628"}},
    {
      "id": "esri-topo",
      "type": "raster",
      "source": "esri-topo",
      "minzoom": 0,
      "maxzoom": 22,
      "paint": {"raster-opacity": 1, "raster-fade-duration": 160}
    }
  ]
}
